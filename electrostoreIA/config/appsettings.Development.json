{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.ML": "Warning"
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Grpc": {
        "Url": "http://0.0.0.0:5001",
        "Protocols": "Http2"
      },
      "Http": {
        "Url": "http://0.0.0.0:5000",
        "Protocols": "Http1"
      }
    }
  },
  "S3": {
    "Enable": false,
    "Endpoint": "<minio-url>:9000",
    "AccessKey": "<access-key>",
    "SecretKey": "<secret-key>",
    "BucketName": "electrostore",
    "Region": "garage",
    "Secure": false
  },
  "Kafka": {
    "BootstrapServers": "192.168.1.101:9092",
    "ConsumerGroupId": "ia-service"
  },
  "ApiServiceGrpcUrl": "http://192.168.1.101:5001",
  "Vault": {
    "Enable": false,
    "Addr": "http://vault:8200",
    "Token": "",
    "Path": "",
    "MountPoint": "secret"
  },
  "DefaultEpochs": 10,
  "DefaultBatchSize": 32
}
